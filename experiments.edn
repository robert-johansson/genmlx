   :sources     ["src/genmlx/conjugacy.cljs"
                 "src/genmlx/inference/auto_analytical.cljs"]}

  {:name        "l3.5-mvn-conjugacy"
   :script      "bench/l3_5_mvn_conjugacy.cljs"
   :category    :analytical
   :timeout-ms  120000
   :description "Multivariate normal-normal conjugacy via mx/solve (no matrix inverse)."
   :sources     ["src/genmlx/inference/kalman.cljs"
                 "src/genmlx/conjugacy.cljs"]}

  {:name        "l3.5-combinator-conjugacy"
   :script      "bench/l3_5_combinator_conjugacy.cljs"
   :category    :analytical
   :timeout-ms  120000
   :description "Conjugacy detection inside Map/Unfold combinators."
   :sources     ["src/genmlx/combinators.cljs"
                 "src/genmlx/conjugacy.cljs"]}

  {:name        "l3.5-regenerate-analytical"
   :script      "bench/l3_5_regenerate_analytical.cljs"
   :category    :analytical
   :timeout-ms  120000
   :description "MCMC with analytical elimination: overhead vs quality gain."
   :sources     ["src/genmlx/inference/mcmc.cljs"
                 "src/genmlx/inference/auto_analytical.cljs"]}

  ;; =========================================================================
  ;; D. Cross-System Comparison
  ;; =========================================================================

  {:name        "cross-system"
   :script      "bench/cross_system.cljs"
   :category    :cross-system
   :timeout-ms  300000
   :description "GenMLX vs Gen.jl vs GenJAX: IS, MCMC, SMC on linreg/HMM/GMM."
   :sources     ["src/genmlx/dynamic.cljs"
                 "src/genmlx/inference/mcmc.cljs"
                 "src/genmlx/inference/importance.cljs"]}

  ;; =========================================================================
  ;; E. Method Selection & Automation
  ;; =========================================================================

  {:name        "method-selection"
   :script      "bench/method_selection.cljs"
   :category    :automation
   :timeout-ms  300000
   :description "L4 fit() auto-routing: 6+ model types to optimal algorithm."
   :sources     ["src/genmlx/method_selection.cljs"
                 "src/genmlx/fit.cljs"]}

  ;; =========================================================================
  ;; F. Verification & Correctness
  ;; =========================================================================

  {:name        "verification-suite"
   :script      "bench/verification_suite.cljs"
   :category    :verification
   :timeout-ms  600000
   :description "All test suite pass rates: L0, L1-M1..M5, L4, compat suites."
   :sources     []}  ;; depends on all source files

  {:name        "gfi-law-verification"
   :script      "bench/gfi_law_verification.cljs"
   :category    :verification
   :timeout-ms  300000
   :description "53 algebraic laws, 64 generated-model properties, pass/fail/time."
   :sources     ["src/genmlx/gfi.cljs"
                 "src/genmlx/protocols.cljs"]}

  {:name        "property-test-stats"
   :script      "bench/property_test_stats.cljs"
   :category    :verification
   :timeout-ms  600000
   :description "Run all property tests, report trial counts, failure rates."
   :sources     []}  ;; depends on all property test files

  {:name        "distribution-audit"
   :script      "bench/distribution_audit.cljs"
   :category    :verification
   :timeout-ms  300000
   :description "All 26 distributions: normalization, moments, gradient checks."
   :sources     ["src/genmlx/dist.cljs"
                 "src/genmlx/dist/core.cljs"]}

  {:name        "mutation-boundary"
   :script      "bench/mutation_boundary.cljs"
   :category    :verification
   :timeout-ms  120000
   :description "12 properties verifying three-layer purity."
   :sources     ["src/genmlx/mlx.cljs"
                 "src/genmlx/runtime.cljs"]}]}
