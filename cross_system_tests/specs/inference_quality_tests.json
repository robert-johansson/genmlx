      "description": "Beta-bernoulli IS log-ML: cross-system comparison"
    },
    {
      "id": "logml-nn-analytical",
      "model": "normal_normal",
      "algorithm": "importance_sampling",
      "algorithm_params": {"n_particles": 5000},
      "comparison": "log_ml_analytical",
