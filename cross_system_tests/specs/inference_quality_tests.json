      "analytical_posterior": {"mean": 0.333, "std": 0.08},
      "target_addr": "p",
      "target_component": 0,
      "description": "Same model, MH inference"
    },
    {
      "id": "logml-nn-is",
      "model": "normal_normal",
      "algorithm": "importance_sampling",
      "algorithm_params": {"n_particles": 5000},
