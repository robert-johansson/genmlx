      "description": "lambda~Gamma(2,1), x_i~Poisson(lambda), 20 obs sum=60. Posterior: Gamma(62,21), mean=62/21"
    },
    {
      "id": "infer-gp-mh",
      "model": "gamma_poisson",
      "algorithm": "mh",
      "algorithm_params": {"n_steps": 2000, "burn": 500},
