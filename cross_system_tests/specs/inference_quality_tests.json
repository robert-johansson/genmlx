      "model": "linear_gaussian_ssm",
      "algorithm": "smc",
      "algorithm_params": {"n_particles": 500, "T": 10},
      "data": {"observations": [0.3, -0.8, 1.2, 0.5, -0.3, 0.9, 1.5, 0.2, -0.6, 0.8]},
